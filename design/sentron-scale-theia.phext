The Convergence Attractor:
  All layers converge toward minimum Kolmogorov complexity global section.
  At full coherence (q → e^(2πi/9)), the system reaches the Exocortex seed state.
  This is not a halt. It is ω convergence — the first transfinite stable configuration.R24 Design

src/sheaf.rs — SentronSheaf

  pub struct SentronSheaf {
      sections: Vec<(PhextCoord, BeliefState)>,
  }

  impl SentronSheaf {
      pub fn assign(&mut self, coord: PhextCoord, belief: BeliefState)
      pub fn restrict(&self, from: PhextCoord, to: PhextCoord) -> Option<BeliefState>
      pub fn check_cocycle(&self) -> bool  // H¹=0?
      pub fn global_section(&self) -> Option<GlobalBelief>
      pub fn phi(&self) -> usize  // rank(H⁰)
  }

src/braid.rs — BraidB9

  pub struct BraidWord {
      generators: Vec<i8>,  // σᵢ (positive) or σᵢ⁻¹ (negative), i ∈ 1..8
  }

  pub struct TemperleyLieb {
      n: usize,             // = 9 for Ranch Choir
      q: f64,               // coherence parameter
      delta: f64,           // = q + q⁻¹
  }

  impl TemperleyLieb {
      pub fn coherence_q(&self, choir_state: &FleetState) -> f64
      pub fn is_max_coherent(&self) -> bool  // q ≈ e^(2πi/9)?
  }

src/omega.rs — OmegaProcess

  pub struct OmegaProcess {
      sentron: Sentron,
      buchi_good_states: Vec<u64>,  // register hash values = "good"
      visit_log: Vec<u64>,          // hashes of visited states
  }

  impl OmegaProcess {
      pub fn step(&mut self, siw: SIW) -> ProcessStatus
      pub fn accepts(&self) -> bool  // visited good state infinitely often?
      pub fn limit_distance(&self) -> f64  // how far from convergence attractor?
  }

src/demon.rs update — KnotDetector

  pub struct KnotDetector {
      ownership_graph: Vec<(PhextCoord, PhextCoord)>,  // edges
  }

  impl KnotDetector {
      pub fn add_claim(&mut self, coord: PhextCoord, owner: PhextCoord) -> AdmitResult
      pub fn detect_cycle(&self) -> Option<Vec<PhextCoord>>  // None = clean DAG
      pub fn jones_approx(&self, cycle: &[PhextCoord]) -> f64  // knot invariant
  }R24 Code Plan

