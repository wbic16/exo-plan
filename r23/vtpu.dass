## 1.1.1/8.* — Code (D-Pipe: Expressed behavior)

### 1.1.1/8.1.1 — Module Structure

```
vtpu-runtime/src/
├── lib.rs          # Public API
├── siw.rs          # Sentron Instruction Word
├── pipes.rs        # D/S/C operation definitions
├── phext_coord.rs  # 11D coordinate handling
├── scheduler.rs    # SIW dispatch
├── stream.rs       # SIW stream builder
├── validation.rs   # Stream correctness checks
├── telemetry.rs    # Performance tracking
└── display.rs      # Debug output
```

### 1.1.1/8.1.2 — Core Types

```rust
// Dense operations (D-Pipe)
pub enum DenseOp {
    DFMA { rd: u8, rs1: u8, rs2: u8, rs3: u8 },
    DADD { rd: u8, rs1: u8, rs2: u8 },
    DSUB { rd: u8, rs1: u8, rs2: u8 },
    DMUL { rd: u8, rs1: u8, rs2: u8 },
    DCMP { rd: u8, rs1: u8, rs2: u8 },
    DSEL { rd: u8, rs1: u8, rs2: u8, flags: u8 },
    DMOV { rd: u8, imm: i64 },
    DNOP,
}

// Sparse operations (S-Pipe)
pub enum SparseOp {
    SGATHER { rd: u8, coord_idx: u8, width: u16 },
    SSCATTER { coord_idx: u8, rs: u8, width: u16 },
    SINDEX { rd: u8, base: u8, offset: u8, dim: u8 },
    SPREFCH { coord_idx: u8, hint: PrefetchHint },
    SALLOC { rd: u8, size: u32, dim_mask: u16 },
    SFREE { coord_idx: u8, size: u32 },
    SNOP,
}

// Coordination operations (C-Pipe)
pub enum CoordOp {
    CPACK { rd: u8, rs1: u8, rs2: u8, fmt: MessageFormat },
    CROUTE { msg_reg: u8, dest_node: u8 },
    CSEND { msg_reg: u8, dest_sentron: u16 },
    CRECV { rd: u8, src_sentron: u16 },
    CBAR { barrier_id: u8, count: u8 },
    CFENCE { scope: FenceScope },
    CNOP,
}
```

